{
    "name": "blockshiftnetwork/composio-laravel",
    "description": "Laravel integration for Composio with PrismPHP and Laravel AI tool support",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "blockshiftnetwork/composio-php": "dev-main",
        "prism-php/prism": "^0.99|^0.100",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/ai": "^0.4"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.3"
    },
    "suggest": {
        "prism-php/prism": "Required for PrismPHP tool conversion (^0.99|^0.100)",
        "laravel/ai": "Required for Laravel AI tool conversion (^0.4)"
    },
    "autoload": {
        "psr-4": {
            "BlockshiftNetwork\\ComposioLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BlockshiftNetwork\\ComposioLaravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BlockshiftNetwork\\ComposioLaravel\\ComposioServiceProvider"
            ],
            "aliases": {
                "Composio": "BlockshiftNetwork\\ComposioLaravel\\Facades\\Composio"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "pint": "pint",
        "pint:check": "pint --test",
        "phpstan": "phpstan analyse",
        "rector": "rector process",
        "rector:dry-run": "rector process --dry-run",
        "quality": [
            "@pint:check",
            "@phpstan",
            "@rector:dry-run"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
